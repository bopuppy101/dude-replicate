#!/usr/bin/env bash
# Stop the Dude Replicate middle tier
set -e

PIDS=$(lsof -ti:8000 2>/dev/null || true)

if [ -z "$PIDS" ]; then
    echo "Middle tier is not running."
    exit 0
fi

echo "Stopping middle tier (PID $PIDS)..."
echo "$PIDS" | xargs kill -TERM 2>/dev/null || true
sleep 2

# Force kill if still running
PIDS=$(lsof -ti:8000 2>/dev/null || true)
if [ -n "$PIDS" ]; then
    echo "$PIDS" | xargs kill -9 2>/dev/null || true
    echo "Force killed."
else
    echo "Middle tier stopped."
fi
