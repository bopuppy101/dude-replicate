# Dude-Replicate environment configuration
# Copy this file to .env and fill in real credentials
# DO NOT commit .env — it is git-ignored

# SQL Server
MSSQL_HOST=127.0.0.1
MSSQL_PORT=1433
MSSQL_USER=sa
MSSQL_PASS=changeme
MSSQL_DB=EnterpriseDW

# PostgreSQL
PG_HOST=127.0.0.1
PG_PORT=5432
PG_USER=postgres
PG_PASS=changeme
PG_DB=enterprise_dw

# Oracle
ORACLE_HOST=127.0.0.1
ORACLE_PORT=1521
ORACLE_USER=repltest
ORACLE_PASS=changeme
ORACLE_SYS_PASS=changeme
ORACLE_CDB_DSN=127.0.0.1:1521/FREE
ORACLE_PDB_DSN=127.0.0.1:1521/FREEPDB1
ORACLE_SCHEMA=REPLTEST

# ─── UI Backend (FastAPI) ────────────────────────────────────────────────────
# Secret key for JWT token signing (generate with: python -c "import secrets; print(secrets.token_hex(32))")
JWT_SECRET=changeme

# Encryption key for endpoint credentials stored in PostgreSQL via pgcrypto
# (generate with: python -c "import secrets; print(secrets.token_hex(32))")
ENCRYPTION_KEY=changeme

# Default admin account (REQUIRED — created on first startup if users table is empty)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme

# API server port
API_PORT=8000
